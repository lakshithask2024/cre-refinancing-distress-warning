# ─── CRE Distress Warning System — Environment Variables ─────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ─── Data APIs ────────────────────────────────────────────────────────────────
# FRED API key for Treasury rate data (https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_api_key_here

# ─── MLflow ───────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT_NAME=cre-distress-classifier

# ─── Data Paths ───────────────────────────────────────────────────────────────
DATA_DIR=./data
BRONZE_PATH=./data/bronze
SILVER_PATH=./data/silver
GOLD_PATH=./data/gold
EXPORT_PATH=./data/exports/powerbi

# ─── Spark ────────────────────────────────────────────────────────────────────
SPARK_MASTER=local[*]
SPARK_APP_NAME=cre-distress-warning
SPARK_DRIVER_MEMORY=4g

# ─── Pipeline ─────────────────────────────────────────────────────────────────
# Number of synthetic loans to generate (default: 10000)
PORTFOLIO_SIZE=10000
# Random seed for reproducibility
RANDOM_SEED=42

# ─── Databricks (production only) ────────────────────────────────────────────
# DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
# DATABRICKS_TOKEN=dapi_your_token_here
# DATABRICKS_SQL_WAREHOUSE_ID=your_warehouse_id
